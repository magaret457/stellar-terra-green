# Web environment variables
# Copy to .env.local and fill in values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stellar
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_ENERGY_TOKEN_CONTRACT_ID=
NEXT_PUBLIC_ENERGY_DISTRIBUTION_CONTRACT_ID=
NEXT_PUBLIC_COMMUNITY_GOVERNANCE_CONTRACT_ID=

# Admin keypair (server-side only — never expose to client)
STELLAR_ADMIN_SECRET_KEY=
